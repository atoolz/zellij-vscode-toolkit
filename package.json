{
  "name": "zellij-vscode-toolkit",
  "displayName": "Zellij Toolkit",
  "description": "Complete Zellij development toolkit: IntelliSense, validation, color preview, and snippets for config and layout files",
  "version": "0.1.3",
  "publisher": "andreahlert",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets",
    "Linters"
  ],
  "keywords": [
    "zellij",
    "kdl",
    "terminal",
    "multiplexer",
    "config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ahlert/zellij-config-vscode"
  },
  "bugs": {
    "url": "https://github.com/ahlert/zellij-config-vscode/issues"
  },
  "homepage": "https://github.com/ahlert/zellij-config-vscode#readme",
  "icon": "assets/icon.png",
  "galleryBanner": {
    "color": "#1e1e2e",
    "theme": "dark"
  },
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:zellij-kdl",
    "workspaceContains:**/.config/zellij/**/*.kdl"
  ],
  "contributes": {
    "languages": [
      {
        "id": "zellij-kdl",
        "aliases": [
          "Zellij Config",
          "zellij-kdl",
          "zellij"
        ],
        "extensions": [],
        "filenames": [
          "config.kdl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "zellij-kdl",
        "scopeName": "source.zellij-kdl",
        "path": "./syntaxes/zellij-kdl.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "zellij-kdl",
        "path": "./snippets/zellij.json"
      }
    ],
    "commands": [
      {
        "command": "zellij-config.setAsZellijConfig",
        "title": "Zellij: Set as Zellij Config"
      },
      {
        "command": "zellij-config.openDocs",
        "title": "Zellij: Open Documentation"
      }
    ],
    "configuration": {
      "title": "Zellij Config",
      "properties": {
        "zellijConfig.zellijBinaryPath": {
          "type": "string",
          "default": "zellij",
          "description": "Path to the Zellij binary (used for version detection)"
        },
        "zellijConfig.enableValidation": {
          "type": "boolean",
          "default": true,
          "description": "Enable real-time validation of config files"
        },
        "zellijConfig.enableColorDecorators": {
          "type": "boolean",
          "default": true,
          "description": "Show inline color decorators for hex colors in theme definitions"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "node esbuild.js --production",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src --ext ts",
    "test": "node ./dist/test/extension.test.js",
    "test:e2e": "tsc -p . && node ./dist/test/runTest.js",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/glob": "^8.1.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.10.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "@vscode/test-electron": "^2.5.2",
    "esbuild": "^0.19.0",
    "eslint": "^8.0.0",
    "glob": "^13.0.6",
    "mocha": "^11.7.5",
    "typescript": "^5.3.0"
  }
}
